    {
      "name": "Unified Events",
      "item": [
        {
          "name": "POST /unified/test/github-sync",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Returns reposSynced and eventsSynced counts\", () => {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.data).to.be.an('object');",
                  "  pm.expect(res.data.reposSynced).to.be.a('number');",
                  "  pm.expect(res.data.eventsSynced).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/unified/test/github-sync",
              "host": ["{{baseUrl}}"],
              "path": ["unified", "test", "github-sync"]
            }
          },
