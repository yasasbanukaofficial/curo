{
  "name": "curo-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Centralized secrets management platform — React frontend for securely storing, managing, versioning, and syncing environment variables across projects and environments",
  "type": "module",
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "keywords": [
    "curo",
    "secrets-management",
    "environment-variables",
    "react",
    "dashboard",
    "typescript",
    "vite"
  ],
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.0",
    "formik": "^2.4.9",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
